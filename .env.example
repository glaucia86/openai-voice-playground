# Server-only. Never prefix this variable with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Optional shared bearer token for public deployments. Keep it server-only.
# If configured, the UI asks visitors for it and keeps it in memory only.
PLAYGROUND_ACCESS_TOKEN=

# Optional canonical origin, for example https://voice.example.com.
# When omitted, the request origin is derived from the incoming URL.
APP_ORIGIN=
